# Copy this file to .env and fill in real values.
# .env is git-ignored — never commit real secrets.

# ── LocalStack dummy credentials ─────────────────────────────────────────────
# These fake credentials are required by the AWS SDK even when hitting LocalStack.
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_REGION=us-east-1

# ── ntfy.sh push notifications ────────────────────────────────────────────────
# Use a unique, hard-to-guess topic name. Anyone who knows the topic can subscribe.
# Install the ntfy app on your phone and subscribe to this topic.
NTFY_TOPIC=your-unique-topic-name
